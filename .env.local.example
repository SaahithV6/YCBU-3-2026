# =============================================================================
# Living Papers v2 — Environment Variables
# =============================================================================
# Copy this file to .env.local:  cp .env.local.example .env.local
# Then fill in your actual keys. Leave blank for demo mode.
# For Vercel: paste each key into Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# 🔴 CORE — needed for full functionality
# -----------------------------------------------------------------------------

# Anthropic Claude API (paper processing)
# Get it: https://console.anthropic.com → API Keys → Create Key
# Cost: Pay-as-you-go, $5 free credit for new accounts
# If missing: paper processing falls back to demo data
ANTHROPIC_API_KEY=

# Browser Use Cloud API (multi-source web search)
# Get it: https://cloud.browser-use.com → Dashboard → API Keys
# Cost: Pay-as-you-go, see https://browser-use.com/pricing
# If missing: search falls back to arXiv only
BROWSER_USE_API_KEY=

# Daytona API (notebook sandboxes)
# Get it: https://app.daytona.io → Profile → API Keys → Generate New Key
# Cost: Free tier available, see https://www.daytona.io/pricing
# If missing: sandbox feature returns 503
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# -----------------------------------------------------------------------------
# 🟡 INFRASTRUCTURE — real-time features & auth
# -----------------------------------------------------------------------------

# Convex (real-time processing status)
# Get it: run `npx convex dev` — it prints this URL automatically
# Cost: Free for small projects, see https://convex.dev/pricing
# If missing: app works, but no live status updates
NEXT_PUBLIC_CONVEX_URL=

# Convex Deployment (auto-set by `npx convex dev`, don't edit manually)
# CONVEX_DEPLOYMENT=dev:your-deployment-name

# Convex Deploy Key (only needed for Vercel production deploys)
# Get it: https://dashboard.convex.dev → your project → Settings → Deploy Keys
CONVEX_DEPLOY_KEY=

# Clerk Authentication (sign-in / sign-up)
# Get it: https://dashboard.clerk.com → Create Application → API Keys
# Cost: FREE up to 10,000 monthly active users
# If missing: auth disabled, core reading still works
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -----------------------------------------------------------------------------
# 🟢 OPTIONAL — persistence, memory, observability
# -----------------------------------------------------------------------------

# MongoDB Atlas (persistent data storage)
# Get it: https://cloud.mongodb.com → Build a Database (free M0 tier) → Connect → Drivers
# Cost: Free M0 tier (512 MB)
MONGODB_URI=

# Supermemory (cross-session paper memory)
# Get it: https://supermemory.ai → Dashboard → API Keys
SUPERMEMORY_API_KEY=

# Laminar (observability / tracing — not currently wired into app code)
# Get it: https://www.lmnr.ai → Settings → API Keys
# Cost: Free tier available
LAMINAR_API_KEY=